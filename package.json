{
  "name": "codexsun",
  "version": "1.0.71",
  "private": true,
  "packageManager": "npm@11.17.0",
  "description": "CODEXSUN",
  "type": "module",
  "workspaces": [
    "apps/*",
    "apps/*/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "predev": "node tools/env-jwt-secret.mjs --ensure",
    "dev": "node tools/clean-app-turbo.mjs && turbo dev --parallel",
    "predev:platform": "node tools/env-jwt-secret.mjs --ensure",
    "dev:platform": "concurrently -n api,web -c cyan,green \"npm run dev -w @codexsun/platform-api\" \"npm run dev -w @codexsun/platform-web\"",
    "predev:platform:skip-db": "node tools/env-jwt-secret.mjs --ensure",
    "dev:platform:skip-db": "concurrently -n api,web -c cyan,green \"npm run dev:skip-db -w @codexsun/platform-api\" \"npm run dev -w @codexsun/platform-web\"",
    "predev:platform:fast": "node tools/env-jwt-secret.mjs --ensure",
    "dev:platform:fast": "concurrently -n api,web -c cyan,green \"npm run dev:fast -w @codexsun/platform-api\" \"npm run dev -w @codexsun/platform-web\"",
    "build": "node tools/clean-root-dist.mjs && node tools/clean-app-turbo.mjs && turbo build && node tools/collect-dist.mjs && node tools/clean-app-turbo.mjs",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "e2e:platform": "playwright test apps/platform/web/e2e",
    "verify:tenant-ui": "npm run typecheck -w @codexsun/platform-web && playwright test apps/platform/web/e2e/tenant-modules.spec.ts",
    "verify:platform-ui": "npm run typecheck -w @codexsun/platform-web && playwright test apps/platform/web/e2e/tenant-modules.spec.ts && npm run e2e:platform",
    "check": "npm run check:module-boundaries && npm run typecheck && npm run lint",
    "check:module-boundaries": "node tools/check-module-boundaries.mjs",
    "version:show": "node tools/version/version.mjs show",
    "version:bump": "node tools/version-bump.mjs",
    "changelog:append": "node tools/version/version.mjs append",
    "check:versions": "node tools/check-versions.mjs",
    "db:create-user": "node tools/create-db-user.mjs",
    "db:migrate": "npm run db:migrate -w @codexsun/platform-api",
    "db:migrate-fresh": "npm run db:migrate-fresh -w @codexsun/platform-api",
    "db:migrate-rollback": "npm run db:migrate-rollback -w @codexsun/platform-api",
    "db:tenant:migrate": "npm run db:tenant:migrate -w @codexsun/platform-api",
    "db:tenant:migrate-fresh": "npm run db:tenant:migrate-fresh -w @codexsun/platform-api",
    "db:tenant:migrate-rollback": "npm run db:tenant:migrate-rollback -w @codexsun/platform-api",
    "db:tenant:drop": "npm run db:tenant:drop -w @codexsun/platform-api",
    "github:now": "node tools/github-helper.mjs",
    "env:jwt-secret": "node tools/env-jwt-secret.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true
  }
}
